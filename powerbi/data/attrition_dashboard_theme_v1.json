{
  "name": "Attrition Dashboard - Navy & Coral",
  "dataColors": [
    "#1B2A4A",
    "#E15554",
    "#1B9C85",
    "#D8A33D",
    "#6C7A96",
    "#A26769",
    "#4C5B7A",
    "#9CA3AF"
  ],
  "background": "#FFFFFF",
  "foreground": "#1B2A4A",
  "tableAccent": "#1B2A4A",
  "good": "#1B9C85",
  "neutral": "#D8A33D",
  "bad": "#E15554",
  "maximum": "#E15554",
  "center": "#FBC97C",
  "minimum": "#EAF3FB",
  "textClasses": {
    "title": {
      "fontSize": 16,
      "fontFace": "Segoe UI Semibold",
      "color": "#1B2A4A"
    },
    "header": {
      "fontSize": 13,
      "fontFace": "Segoe UI Semibold",
      "color": "#52607A"
    },
    "label": {
      "fontSize": 11,
      "fontFace": "Segoe UI",
      "color": "#52607A"
    },
    "callout": {
      "fontSize": 40,
      "fontFace": "Segoe UI Semibold",
      "color": "#1B2A4A"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#EDF1F7" } },
            "transparency": 0
          }
        ]
      }
    },
    "card": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#F6F8FB" } },
            "transparency": 0
          }
        ],
        "labels": [
          {
            "color": { "solid": { "color": "#1B2A4A" } },
            "fontSize": 40,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "color": { "solid": { "color": "#6B7280" } },
            "fontSize": 13,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "columnHeaders": [
          {
            "fontColor": { "solid": { "color": "#FFFFFF" } },
            "backColor": { "solid": { "color": "#1B2A4A" } },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 11,
            "alignment": "Left"
          }
        ],
        "values": [
          {
            "fontColorPrimary": { "solid": { "color": "#1B2A4A" } },
            "backColorPrimary": { "solid": { "color": "#FFFFFF" } },
            "fontColorSecondary": { "solid": { "color": "#1B2A4A" } },
            "backColorSecondary": { "solid": { "color": "#F6F8FB" } },
            "fontFamily": "Segoe UI",
            "fontSize": 11
          }
        ],
        "grid": [
          {
            "gridVertical": false,
            "gridHorizontal": true,
            "gridHorizontalColor": { "solid": { "color": "#E5E7EB" } },
            "rowPadding": 6,
            "outlineColor": { "solid": { "color": "#E5E7EB" } },
            "outlineWeight": 1,
            "textSize": 11
          }
        ]
      }
    },
    "pivotTable": {
      "*": {
        "columnHeaders": [
          {
            "fontColor": { "solid": { "color": "#FFFFFF" } },
            "backColor": { "solid": { "color": "#1B2A4A" } },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 11,
            "alignment": "Left"
          }
        ],
        "rowHeaders": [
          {
            "fontColor": { "solid": { "color": "#1B2A4A" } },
            "backColor": { "solid": { "color": "#F6F8FB" } },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 11
          }
        ],
        "grid": [
          {
            "gridVertical": true,
            "gridVerticalColor": { "solid": { "color": "#E5E7EB" } },
            "gridHorizontal": true,
            "gridHorizontalColor": { "solid": { "color": "#E5E7EB" } },
            "rowPadding": 4,
            "outlineColor": { "solid": { "color": "#E5E7EB" } },
            "outlineWeight": 1,
            "textSize": 11
          }
        ]
      }
    }
  }
}